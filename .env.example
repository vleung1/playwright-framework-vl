# Which CRDC hub to use: prod | qa | stage | qa2 (see config/env/urls.ts for URLs).
# When unset, the code default is **qa** (see config/constants.ts) so local runs avoid production.
# Set only TEST_ENV to use that env's default URL. Optional: set BASE_URL to override.
# If both are set, BASE_URL wins.
TEST_ENV=qa
# BASE_URL=

# Optional: credentials — use env or secrets manager; never commit real values
# TEST_USER_EMAIL=
# TEST_USER_PASSWORD=
